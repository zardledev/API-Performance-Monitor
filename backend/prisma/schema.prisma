generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Endpoint {
  id          String         @id @default(uuid())
  name        String
  url         String
  method      String
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tests       EndpointTest[]
}

model EndpointTest {
  id         String   @id @default(uuid())
  endpointId String
  status     Int
  duration   Int
  success    Boolean
  createdAt  DateTime @default(now())

  endpoint Endpoint @relation(fields: [endpointId], references: [id])
}